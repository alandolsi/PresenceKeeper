{
  "name": "presencekeeper",
  "version": "0.1.0",
  "description": "Windows desktop app to simulate periodic activity with start/stop and scheduling.",
  "main": "src/main.js",
  "author": "Landolsi Webdesign <info@landolsi.de> (https://landolsi.de)",
  "license": "MIT",
  "scripts": {
    "css:build": "tailwindcss -c tailwind.config.js -i ./src/renderer/tailwind.input.css -o ./src/renderer/tailwind.css --minify",
    "predev": "npm run css:build",
    "dev": "electron .",
    "prebuild": "npm run css:build",
    "build": "electron-builder --dir",
    "predist": "npm run css:build",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^3.4.17"
  },
  "build": {
    "appId": "de.landolsi.presencekeeper",
    "productName": "PresenceKeeper",
    "files": [
      "src/**/*",
      "worker/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
